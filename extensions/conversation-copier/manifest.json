{
  "manifest_version": 3,
  "name": "Recurate Copier",
  "description": "Export your full AI conversation. Copy as markdown, download as HTML, or export as ZIP with artifacts and uploads.",
  "version": "0.2.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://grok.com/*",
        "*://gemini.google.com/*",
        "*://www.google.com/*",
        "*://copilot.microsoft.com/*",
        "*://m365.cloud.microsoft/*"
      ],
      "js": ["jszip.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
