{
  "manifest_version": 3,
  "name": "Recurate Copier",
  "description": "Export your full AI conversation — messages, artifacts, and uploads. One click for markdown, or download as a complete ZIP archive.",
  "version": "0.3.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "alarms",
    "downloads",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://grok.com/*",
        "*://gemini.google.com/*",
        "*://www.google.com/*",
        "*://copilot.microsoft.com/*",
        "*://m365.cloud.microsoft/*"
      ],
      "js": ["jszip.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
